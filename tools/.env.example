# Credenciais para o script de export. NÃO COMMITAR um .env real.

# Encontre no painel do Base44 → Settings → App Settings
LEGACY_APP_ID=
LEGACY_APP_BASE_URL=https://seu-app.base44.app

# Token de service role (para acesso completo). Painel do Base44 → API Keys
LEGACY_API_KEY=

# Lista de entidades para exportar (vírgula). Se vazio, descobre via /entities
# Use isso se descobrir nomes adicionais via UI do Base44
LEGACY_ENTITIES=

# Pasta de saída (default: ./dump)
DUMP_DIR=./dump

# Baixar arquivos referenciados (URLs em campos *_url, foto_url, arquivo_url, etc.)?
DOWNLOAD_FILES=true

# ============================================================================
# Para seed-from-xlsx.mjs
# ============================================================================

# Supabase (use service-role-key para bypass de RLS no seed)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Caminho para o backup_todas_empresas_*.xlsx
XLSX_PATH=C:/Users/javer/Downloads/backup_todas_empresas_2026-05-24.xlsx

# Simulação: lê tudo, mas não escreve no banco. Use para validar antes.
DRY_RUN=false
