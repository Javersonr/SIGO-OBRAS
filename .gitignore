# ============================================================================
# .gitignore — SIGO Obras
# ============================================================================

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
.pnpm-store/
.yarn/
.npm/

# ---------------------------------------------------------------------------
# Build outputs
# ---------------------------------------------------------------------------
dist/
build/
.next/
.turbo/
.cache/
coverage/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Environment variables (NUNCA commitar — exceto .env.example)
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
!.env.example
!.env.template

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# ---------------------------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
supabase/.branches/
supabase/.temp/
supabase/.env

# ---------------------------------------------------------------------------
# Dados produtivos (NUNCA commitar)
# ---------------------------------------------------------------------------
tools/dump/
tools/dump-archive/
*.dump
*.backup

# ---------------------------------------------------------------------------
# Husky (não ignora _/ — Husky 9+ tem suporte direto)
# ---------------------------------------------------------------------------
.husky/_/

# ---------------------------------------------------------------------------
# Testes
# ---------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
.local/
*.pid
*.seed
*.pid.lock
.eslintcache
.stylelintcache
