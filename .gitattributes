# Normaliza LF em todo lugar (resolve os warnings CRLF do Windows)
* text=auto eol=lf

# Sempre LF
*.sh        text eol=lf
*.mjs       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sql       text eol=lf
*.toml      text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.htaccess  text eol=lf

# CRLF apenas em arquivos Windows-específicos
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binários (nunca diff)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.pdf       binary
*.xlsx      binary
*.xls       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
