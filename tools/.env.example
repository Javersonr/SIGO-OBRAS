# Credenciais para o script de export. NÃO COMMITAR um .env real.

# Encontre no painel do Base44 → Settings → App Settings
BASE44_APP_ID=
BASE44_APP_BASE_URL=https://seu-app.base44.app

# Token de service role (para acesso completo). Painel do Base44 → API Keys
BASE44_API_KEY=

# Lista de entidades para exportar (vírgula). Se vazio, descobre via /entities
# Use isso se descobrir nomes adicionais via UI do Base44
BASE44_ENTITIES=

# Pasta de saída (default: ./dump)
DUMP_DIR=./dump

# Baixar arquivos referenciados (URLs em campos *_url, foto_url, arquivo_url, etc.)?
DOWNLOAD_FILES=true
